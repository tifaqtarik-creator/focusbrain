generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  HOMME
  FEMME
  NON_BINAIRE
  PREFERE_NE_PAS_DIRE
}

enum DiagnosisStatus {
  DIAGNOSTIQUE
  EN_COURS
  AUTO_DIAGNOSTIQUE
  NON_DIAGNOSTIQUE
}

enum WorkObjective {
  FOCUS_TRAVAIL
  TROUVER_PARTENAIRES
  RENCONTRER_TDAH
  CREER_ROUTINES
  PARTAGER_EXPERIENCE
  GERER_EMOTIONS
}

enum TdahType {
  INATTENTIF
  HYPERACTIF
  COMBINE
  NON_SPECIFIE
  PREFERE_NE_PAS_DIRE
}

enum WorkStyle {
  SILENCIEUX
  SOCIAL
  FLEXIBLE
}

enum SessionStatus {
  WAITING
  ACTIVE
  DONE
  SOLO
}

enum UserRole {
  USER
  PREMIUM
  TEAMS
  COACH
  MODERATOR
  ADMIN
}

enum BadgeType {
  PREMIER_PAS
  REGULIER
  BODY_DOUBLER
  CERCLE_FIDELE
  EARLY_ACTIVATOR
  REBOUND_CHAMPION
  BRAIN_BREAK_MASTER
}

enum ForumSpace {
  STRATEGIES_TDAH
  MEDICATION
  OUTILS
  TRAVAIL
  ETUDES
  VIE_PERSO
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String?
  googleId        String?      @unique
  name            String
  avatar          String?
  phone           String?
  gender          Gender?
  birthDate       DateTime?
  timezone        String       @default("Africa/Casablanca")
  tdahType        TdahType?
  diagnosisStatus DiagnosisStatus?
  workStyle       WorkStyle    @default(FLEXIBLE)
  workObjectives  WorkObjective[]
  availabilities  String[]
  bio             String?
  sensitivities   String[]
  goals           String[]
  onboardingDone  Boolean      @default(false)
  // ADAH AI — Avatar thérapeute personnalisé
  aiAvatarUrl     String?      // URL du modèle 3D Ready Player Me (.glb)
  aiAvatarGender  String?      @default("FEMME")  // FEMME | HOMME
  aiVoicePref     String?      @default("douce")  // douce | posee | dynamique
  aiAvatarStyle   String?      @default("chaleureux") // chaleureux | direct
  role            UserRole     @default(USER)
  isPremium       Boolean      @default(false)
  stripeId        String?      @unique
  payments        Payment[]
  emailVerified   Boolean      @default(false)
  lowStimMode     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  sessions        Participant[]
  circleAs        CircleMember[] @relation("CircleUser")
  circleOf        CircleMember[] @relation("CirclePartner")
  badges          Badge[]
  moodLogs        MoodLog[]
  forumPosts      ForumPost[]
  subscription    Subscription?
  coachProfile    CoachProfile?
  refreshTokens   RefreshToken[]
  slotsCreated      Slot[]            @relation("SlotCreator")
  slotsJoined       Slot[]            @relation("SlotPartner")
  slotRequests      SlotRequest[]
  slotFeedbacks     SlotFeedback[]
  location          UserLocation?
  messagesSent      Message[]         @relation("MessageFrom")
  messagesReceived  Message[]         @relation("MessageTo")
  proposalsSent     MeetingProposal[] @relation("ProposalFrom")
  proposalsReceived MeetingProposal[] @relation("ProposalTo")
  adahSessions      AdahSession[]
  adahMemories      AdahMemory[]
  tdahPlaces        TdahPlace[]

  @@map("users")
}

// ── ADAH AI — Sessions TCC ───────────────────────────────────────────────────
model AdahSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("Session TCC")
  mode       String        @default("chat")   // chat | voice | video | audio_tcc
  mood       String?                           // humeur avant session
  summary    String?                           // résumé automatique
  insights   String[]                          // insights clés extraits
  duration   Int           @default(0)         // durée en secondes
  phaseIndex Int           @default(0)         // phase TCC courante (0-3)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  AdahMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("adah_sessions")
}

model AdahMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String                             // user | assistant
  content   String
  emotion   String?                            // Hume AI (future)
  tokens    Int?                               // tokens utilisés
  createdAt DateTime    @default(now())
  session   AdahSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@map("adah_messages")
}

// Mémoire long terme — résumés des sessions passées (RAG simplifié)
model AdahMemory {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("insight")      // insight | goal | pattern | progress
  content   String                             // texte résumé
  tags      String[]
  relevance Float    @default(1.0)             // score de pertinence
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("adah_memories")
}

model Session {
  id           String        @id @default(cuid())
  duration     Int
  quietMode    Boolean       @default(false)
  soloMode     Boolean       @default(false)
  cameraOff    Boolean       @default(false)
  status       SessionStatus @default(WAITING)
  dailyRoomUrl String?
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime      @default(now())

  participants Participant[]
  moodLogs     MoodLog[]

  @@map("sessions")
}

model Participant {
  id             String   @id @default(cuid())
  sessionId      String
  userId         String
  moodBefore     Int[]
  task           String?
  brainBreakUsed Boolean  @default(false)
  joinedAt       DateTime @default(now())
  leftAt         DateTime?

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@map("participants")
}

model CircleMember {
  id           String   @id @default(cuid())
  userId       String
  partnerId    String
  sessionCount Int      @default(0)
  createdAt    DateTime @default(now())

  user    User @relation("CircleUser", fields: [userId], references: [id])
  partner User @relation("CirclePartner", fields: [partnerId], references: [id])

  @@unique([userId, partnerId])
  @@map("circle_members")
}

model Badge {
  id        String    @id @default(cuid())
  userId    String
  type      BadgeType
  earnedAt  DateTime  @default(now())
  shownAt   DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@map("badges")
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  energy    Int
  stress    Int
  anxiety   Int
  focus     Int
  fatigue   Int
  loggedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@map("mood_logs")
}

model ForumPost {
  id             String     @id @default(cuid())
  userId         String
  spaceId        ForumSpace
  title          String     @default("")
  content        String
  images         String[]
  tags           String[]
  emojiReactions Json       @default("{}")
  isPinned       Boolean    @default(false)
  parentId       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user   User       @relation(fields: [userId], references: [id])
  parent ForumPost? @relation("PostReplies", fields: [parentId], references: [id])
  replies ForumPost[] @relation("PostReplies")

  @@map("forum_posts")
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String   @unique
  stripeSubId       String   @unique
  plan              String
  status            String
  currentPeriodEnd  DateTime
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

model CoachProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  certifications String[]
  specialties    String[]
  bookingUrl     String?
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("coach_profiles")
}

model UserLocation {
  id           String   @id @default(cuid())
  userId       String   @unique
  lat          Float
  lng          Float
  city         String?
  country      String?
  isVisible    Boolean  @default(true)
  status       String   @default("DISPONIBLE")  // statut personnalisé
  statusExpiry DateTime?                          // expiration automatique
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  @@map("user_locations")
}

// Lieux TDAH-friendly validés par la communauté
model TdahPlace {
  id          String   @id @default(cuid())
  name        String
  type        String                             // CAFE | LIBRARY | COWORKING | PARK | OTHER
  lat         Float
  lng         Float
  address     String?
  city        String?
  country     String   @default("MA")
  isQuiet     Boolean  @default(false)
  hasWifi     Boolean  @default(false)
  tdahScore   Float    @default(0)              // score validé par communauté
  validations Int      @default(0)              // nb de validations membres
  addedBy     String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [addedBy], references: [id])
  @@map("tdah_places")
}

model Message {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  from User @relation("MessageFrom", fields: [fromId], references: [id])
  to   User @relation("MessageTo",   fields: [toId],   references: [id])
  @@map("messages")
}

model MeetingProposal {
  id         String   @id @default(cuid())
  fromId     String
  toId       String
  type       String   @default("CAFE")
  proposedAt DateTime
  location   String?
  message    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  from User @relation("ProposalFrom", fields: [fromId], references: [id])
  to   User @relation("ProposalTo",   fields: [toId],   references: [id])
  @@map("meeting_proposals")
}

model Slot {
  id           String   @id @default(cuid())
  creatorId    String
  partnerId    String?
  startTime    DateTime
  duration     Int
  status       String   @default("OPEN")
  liveRoomName String?
  creatorTask  String?  // ce que le créateur veut faire
  partnerTask  String?  // ce que le partenaire veut faire
  createdAt    DateTime @default(now())

  creator   User           @relation("SlotCreator", fields: [creatorId], references: [id])
  partner   User?          @relation("SlotPartner", fields: [partnerId], references: [id])
  requests  SlotRequest[]
  feedbacks SlotFeedback[]

  @@map("slots")
}

// Satisfaction post-session body doubling
model SlotFeedback {
  id        String   @id @default(cuid())
  slotId    String
  userId    String                         // qui donne l'avis
  rating    Int                            // 1-5 étoiles
  comment   String?                        // commentaire optionnel
  mood      String?                        // emoji humeur après session
  createdAt DateTime @default(now())

  slot Slot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([slotId, userId])              // 1 avis par personne par session
  @@map("slot_feedbacks")
}

model SlotRequest {
  id            String   @id @default(cuid())
  slotId        String
  userId        String
  status        String   @default("WAITING")
  candidateTask String?  // ce que le candidat veut faire
  createdAt     DateTime @default(now())

  slot Slot @relation(fields: [slotId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([slotId, userId])
  @@map("slot_requests")
}

// ── Paiements PayPal ─────────────────────────────────────────────────────────
model Payment {
  id          String   @id @default(cuid())
  userId      String
  orderId     String   @unique  // ID PayPal
  amount      Float
  currency    String   @default("EUR")
  status      String   @default("PENDING") // PENDING | COMPLETED | FAILED | REFUNDED
  plan        String   @default("PREMIUM")  // PREMIUM | DONATION
  method      String?  // paypal | card | google_pay
  paypalEmail String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id])
  @@map("payments")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}
